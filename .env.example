# =============================================================
# Lumen Environment Variables
# Copy to .env and fill in real values before starting.
# =============================================================

# Application
APP_NAME=Lumen
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://lumen:lumen@localhost:5432/lumen

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Security — CHANGE BEFORE PRODUCTION
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_64_CHAR_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ---- AI APIs ----
# Google AI (Gemini primary + gemini-embedding-001)
GOOGLE_API_KEY=your-google-ai-studio-key-here

# OpenAI (fallback)
OPENAI_API_KEY=sk-your-openai-key-here

# Legacy alias (still supported)
GEMINI_API_KEY=your-google-ai-studio-key-here

AI_ENABLED=true
AI_TIMEOUT_SECONDS=30

# Media storage
MEDIA_PATH=./media
MAX_PHOTO_SIZE_MB=10
MAX_VIDEO_SIZE_MB=50
MAX_VIDEO_DURATION_SECONDS=30
BLUR_VARIANCE_THRESHOLD=100.0

# Rate limiting
RATE_LIMIT_ANONYMOUS_PER_HOUR=10
RATE_LIMIT_USER_PER_HOUR=50

# Frontend
FRONTEND_URL=http://localhost:5173
# Google Maps Platform (optional — enhances map quality)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Push notifications (optional — VAPID keys for web push)
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_EMAIL=admin@lumen.civic

# Firebase Cloud Messaging (push notifications)
FIREBASE_CREDENTIALS_PATH=/path/to/serviceAccount.json
FCM_ENABLED=false

# Geocoding
NOMINATIM_URL=https://nominatim.openstreetmap.org
GEOCODING_USER_AGENT=lumen-civic-app/1.0

# Feature flags
PREDICTIVE_ENABLED=true
GAMIFICATION_ENABLED=true
EMERGENCY_ALERTS_ENABLED=true

# Gamification thresholds
DISPUTE_REOPEN_THRESHOLD=3
HARD_VERIFICATION_RADIUS_METERS=100.0
FLAG_THRESHOLD=5
