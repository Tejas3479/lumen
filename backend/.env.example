# Lumen Environment Variables
# Copy this file to .env and fill in your values.

# Application
APP_NAME=Lumen
ENVIRONMENT=development
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://lumen:lumen@localhost:5432/lumen

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Security — CHANGE THIS IN PRODUCTION
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_64_CHAR_RANDOM_STRING

# AI APIs (optional — leave blank to disable AI categorization)
OPENAI_API_KEY=
GEMINI_API_KEY=

# CORS — comma-separated list of allowed origins.
# Add your production frontend URL here.
CORS_ORIGINS=http://localhost:5173

# Media
MEDIA_PATH=./media

# Push Notifications (optional)
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_EMAIL=admin@lumen.civic
